config LIB_STSELIB
    bool "Enable ST STSELib support"
    default n
    help
      Access the STMicroelectronics STSELib.
    depends on SHIELD_ZEST_SECURITY_SECUREELEMENT

if LIB_STSELIB

config STSE_FRAME_DEBUG
    bool "Enable STSE Frame Debug"
    default n
    help
      Enable this option to activate the STSE Frame Debug feature.

config STSE_USE_HOST_SESSION
    bool "Enable host session for secure channel"
    default n
    select BUILD_WITH_TFM
    help
      Enable this option to use the host session for the secure channel.

choice
    prompt "STSAFE Chip"
    depends on LIB_STSELIB
    default STSAFE_A120

config STSAFE_A110
    bool "STSAFE A110"

config STSAFE_A120
    bool "STSAFE A120"

endchoice # STSAFE Chip

config STSE_USE_RSP_POLLING
    bool "Use polling for RSP pin"
    default y

config STSE_MAX_POLLING_RETRY
    int "Maximum number of polling retries"
    default 10
    depends on STSE_USE_RSP_POLLING

config STSE_FIRST_POLLING_INTERVAL
    int "Initial polling interval in milliseconds"
    default 33
    depends on STSE_USE_RSP_POLLING

config STSE_POLLING_RETRY_INTERVAL
    int  "Polling retry interval in milliseconds"
    default 100
    depends on STSE_USE_RSP_POLLING


endif # LIB_STSELIB
